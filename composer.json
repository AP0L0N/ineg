{
  "require": {
    "craftcms/cms": "^3.7.27.2",
    "craftcms/redactor": "^2.9.1",
    "enupal/translate": "^2.0.0",
    "ether/seo": "^3.7.7",
    "misterbk/mix": "^1.5.2",
    "sendinblue/api-v3-sdk": "^7.4.0",
    "spacecatninja/imager-x": "^3.6",
    "verbb/expanded-singles": "^1.2.0",
    "verbb/navigation": "^1.3.26",
    "verbb/super-table": "^2.6.8",
    "vlucas/phpdotenv": "^3.4.0"
  },
  "require-dev": {
    "yiisoft/yii2-shell": "^2.0.3"
  },
  "autoload": {
    "psr-4": {
      "modules\\custommodule\\": "modules/custommodule/src/",
      "modules\\": "modules/"
    }
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.0"
    },
    "allow-plugins": {
      "yiisoft/yii2-composer": true,
      "craftcms/plugin-installer": true
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ]
  }
}
