<section class="slice procedure-block sct-color-2">
    <div class="container">

        <div class="section-title section-title-inverse section-title--style-1 text-center mb-5">
            <div class="icon-block icon-block--style-2-v1 text-center mb-2">
                <div class="block-icon circle bg-base-1 mb-3">
                    <i class="fal fa-hammer"></i>
                </div>
            </div>
            <h3 class="heading heading-3 text-dark mb-4">
                {{ field.heading }}
            </h3>
            <span class="section-title-delimiter clearfix d-none"></span>
        </div>

        {% for item in field.tutorial.all() %}
            <div class="row align-items-center">
                
                <div class="{{ loop.index % 2 == 0 ? "col-lg-6" : "col-lg-6 order-lg-2" }}">
                    <div class=" {{ loop.index % 2 == 0 ? "col-wrapper--spaced text-left text-md-right animate-on-scroll fadeInUp p-3 p-md-5" : "col-wrapper--spaced text-left animate-on-scroll fadeInUp p-3 p-md-5" }}" data-wow-delay="0.3s">
                        <h3 class="heading heading-4 strong-600 text-normal">
                            <span class="number">{{ loop.index }}.</span> {{ item.heading | nl2br }}
                        </h3>
                        <p>
                            {{ item.description | nl2br }}
                        </p>
                    </div>
                </div>

                <div class="{{ loop.index % 2 == 0 ? "col-lg-3" : "col-lg-3 order-lg-1 ml-lg-auto" }}">
                    <div class=" {{ loop.index % 2 == 0 ? "blog block-image-holder animate-on-scroll fadeInUp" : "blog block-image-holder animate-on-scroll fadeInUp" }}">
                        <div class="block-image text-center text-md-left">
                            {% include "helpers/picture" with {desktop: {image: item.image.one(), width: 255} } %}
                        </div>
                    </div>
                </div>
            </div>

            <span class="space-xs-only-3 space-sm-only-3"></span>
        {% endfor %}
    </div>

    {% if field.blog.one() %}
    <div class="container container-sm d-flex align-items-center mt-5">
        <div class="col">
            <div class="row py-3 text-center justify-content-center">
                <div class="col-12 col-md-10">
                    {% set blog = field.blog.one() %}
                    <h2 class="heading-5 line-height-1_8 animated d-block d-md-flex justify-content-center align-items-center" data-animation-in="fadeIn" data-animation-delay="400">
                        <span class="mr-md-4 d-block d-md-inline-block mb-3 mb-md-0">{{ blog.blogInfo.naslov }}</span>
                        <a href="{{ blog.url }}" target="_blank" class="btn btn-primary">
                            {{ "Preberite si več" | t }}
                        </a>
                    </h2>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</section>