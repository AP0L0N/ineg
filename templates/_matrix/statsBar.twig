{#
    Statistike / trust bar
    data.stats (array) -> { value(number), suffix(string), label(string) }
#}
{% set data = data is defined ? data : {} %}
{% set stats = data.stats is defined ? data.stats : [] %}

<section class="stats-bar">
    <div class="container">
        <div class="stats-grid">
            {% for stat in stats %}
                <div class="stat-item">
                    <div class="stat-value">
                        <span class="counter" data-target="{{ stat.value }}">{{ stat.value }}</span>{% if stat.suffix is defined %}<span class="suffix">{{ stat.suffix }}</span>{% endif %}
                    </div>
                    <div class="stat-label">{{ stat.label }}</div>
                </div>
            {% endfor %}
        </div>
    </div>
</section>
