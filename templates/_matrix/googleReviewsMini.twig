<script src="/assets/js/vue.global.{{ craft.app.config.env == 'production' ? 'prod.' : '' }}js"></script>
<script>
    const googleReviewsMini = Vue.createApp({
        data() {
            return {
                expanded: false,
                googleReviews: {
                    rating: '',
                    reviews: []
                }
            }
        },
        delimiters: ['[[', ']]'],
        computed: {
            ratingRange() {
                return Array.from({ length: this.endNumber }, (_, i) => i + 1);
            }
        },
        methods: {
            toggleExpanded() {
                if(this.expanded === false) {
                    this.expanded = true;
                }
            },
            closeExpanded() {
                setTimeout(() => {
                    this.expanded = false;
                }, 100);
            }
        },
        mounted() {
            fetch('/actions/custom-module/reviews/get-google-reviews')
                .then(response => response.json())
                .then(data => {
                    data.data.result.reviews = data.data.result.reviews.filter(review => review.rating > 3);
                    data.data.result.reviews = data.data.result.reviews.slice(0, 20);
                    this.googleReviews = data.data.result;
                });
        }
    });

    googleReviewsMini.mount('#googleReviewsMini');
</script>