                    </div>

                    <div class="col-lg-3 order-lg-1 ml-lg-auto">
                        <div class="blog block-image-holder animate-on-scroll fadeInUp">
                            <div class="block-image">
                                <img src="/assets/images/24_a.jpg" class="shadow-lg">
                            </div>
                        </div>
                    </div>
                </div>

                <span class="space-xs-only-3 space-sm-only-3"></span>

                <div class="row align-items-center mt-0">
