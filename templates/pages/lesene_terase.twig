{% extends '_layouts/site-content' %}

{# If you need to exclude a field from the loops, add it's handle to the excludes array #}
{% set excludes = ['metadataAndSeo'] %}

{% set seoTitle = "Lesene terase" %}
{% set seoDescription = "Najboljše, kar lahko podarite zunanjemu izgledu vašega doma. Les postaja zopet modern, saj je v zadnjih letih napredovala tehnologija obdelave lesa, strokovnost in vizualizacija uporabe lesa tako znotraj vašega doma, kot tudi zunaj. Razumljivo je, da se zmeraj več lastnikov hiš, vikendov in pritličnih atrijskih stanovanj odloči za leseno teraso. Lesena terasa je poleg svoje fukcionalnsti privlačna predvsem zaradi svojega izgleda in možnosti kombiniranja z drugimi materiali, ki zunanjosti dajejo pridih elegantnosti in udobnosti tako okolice, kot tudi samega doma. S pravo izbiro lesa in načinom montaže lahko dosežemo skladnost in harmonijo bivanja ter dosežemo maksimalni učinek udobja in povezanosti z naravo." %}

