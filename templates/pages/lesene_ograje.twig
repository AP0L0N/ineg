                                        <li class="price">
                                            <strong>Cena ograje:</strong> <span class="text-primary">595 EUR (z DDV)</span>
                                        </li>
                                        <li class="price">
                                            <strong>Cena na m<span class="square">2</span>:</strong> <span class="text-primary">85 EUR (z DDV)</span>
                                        </li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- Info modul ograje -->
