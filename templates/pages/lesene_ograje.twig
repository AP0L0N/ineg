                                        <li>
                                            <strong>Velikost:</strong> 10m<span class="square">2</span>
                                        </li>
                                        <li>
                                            <strong>Vrsta lesa:</strong> sibirski macesen; BC kat.
                                        </li>
                                        <li>
                                            <strong>Obstojnost:</strong> 15 let
                                        </li>
                                        <li>
                                            <strong>Konstrukcija:</strong> kovinski stebri; vidno vijačenje
                                        </li>
                                        <li>
                                            <strong>Postavitev:</strong> vodoravna
                                        </li>
                                        <li>
                                            <strong>Montaža:</strong> ojačano z vertikalno letvijo; razmak 1 cm; kasneje oljeno
                                        </li>
                                        <li class="price">
                                            <strong>Cena ograje:</strong> <span class="text-primary">550 EUR (z DDV)</span>
                                        </li>
                                        <li class="price">
                                            <strong>Cena na m<span class="square">2</span>:</strong> <span class="text-primary">55 EUR (z DDV)</span>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="example-block">
                                <div class="block block-image-holder ">
                                    <div class="block-image">
                                        <img src="/assets/images/lesene_ograje/4.jpg">
                                    </div>
                                </div>
                                <div class="max-content">
