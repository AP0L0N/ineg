                                                <span class="text">{{ blog.blogInfo.naslov }}</span> <span class="circle"><i class="fal fa-angle-right"></i></span>
                                            </a>
                                        </li>
                                        <li>
                                            {% set blog = craft.entries().section('blogs').id(507).one() %}
                                            <a href="{{ blog.url }}" class="link-with-circle">
                                                <span class="text">{{ blog.blogInfo.naslov }}</span> <span class="circle"><i class="fal fa-angle-right"></i></span>
                                            </a>
                                        </li>
                                    </ul>
                                </div>


                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-4">
                        <div class="card example-card">

                            <img class="card-img-top" src="/assets/images/lesene_ograje/lesene-ograje-modul23.jpg" alt="Card image cap">
                            <div class="list-blogs small-divide mt-0">
                                <div class="lightbulp-wrapper">
                                    <div class="circle">
                                        <img src='/assets/images/zarnica_bela.png' class='img-fluid' alt='Slika žarnice'>
                                    </div>
                                </div>

