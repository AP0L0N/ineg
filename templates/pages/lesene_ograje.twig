                                    <div class="block-image">
                                        <img src="/assets/images/lesene_ograje/2.jpg">
                                    </div>
                                </div>
                                <div class="max-content">
                                    <p class="title">
                                        Apartma na podeželju
                                    </p>
                                    <ul>
                                        <li>
                                            <strong>Velikost:</strong> 17m<span class="square">2</span>
                                        </li>
                                        <li>
                                            <strong>Vrsta lesa:</strong> sibirski macesen; AB kat.
                                        </li>
                                        <li>
                                            <strong>Obstojnost:</strong> 25 let
                                        </li>
                                        <li>
                                            <strong>Konstrukcija:</strong> lesena; pritrjena na cinkana držala
                                        </li>
                                        <li>
                                            <strong>Postavitev:</strong> napična in masivna
                                        </li>
                                        <li>
                                            <strong>Montaža:</strong> obdelani leseni stebrički; razmak 5 cm; kasneje oljeno z arganovim oljem
                                        </li>
                                        <li class="price">
                                            <strong>Cena ograje:</strong> <span class="text-primary">935 EUR (z DDV)</span>
                                        </li>
                                        <li class="price">
                                            <strong>Cena na m<span class="square">2</span>:</strong> <span class="text-primary">55 EUR (z DDV)</span>
                                        </li>
                                    </ul>
                                </div>
                            </div>

                            <div class="example-block">
                                <div class="block block-image-holder ">
