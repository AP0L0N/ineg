{% extends '_layouts/site-content' %}

{# If you need to exclude a field from the loops, add it's handle to the excludes array #}
{% set excludes = ['metadataAndSeo'] %}

{% set seoTitle = "Lesene ograje" %}
{% set seoDescription = "Estetska kombinacija funkcionalnosti uporabljenih materialov, ter odličen občutek zasebnosti vašega doma. Les kot material se je v zadnjh letih pričel veliko kombinirati z drugimi materiali, ki se tudi uporabljajo za zunanje ograje. V najpogostejši kominaciji je s kaljenim steklom, perforirano pločevino, gabioni ter žičnato in panelno ograjo. Lesena zunanja ograja je tako postala osnovna kombinacija za odlično ujemanje, tako z naravnimi, kot tudi kovinskimi in plastičnimi materiali, ki jih najdemo v posameznih elementih v okolici hiše. Dandanes je prava kombinacija lesene fasade, lesene ograje in lesene ograje postala sinonim za odlično zlitje hiše in okolice v naravno sobivanje človeka z naravo. Preprosto povedano: Les je bil in bo vedno moderen. Uporabljajo se zgolj različne tehnike obdelave in postavitve, ter kombiniranje tradicionalnih in modernih vrednot in okusov." %}

{% block content %}

    {% if entry is defined %}

        <!-- Naslovni modul -->
        <section class="sct-color-2 custom-main-banner" style="background-image: url(/assets/images/lesene_ograje/lesene-ograje-banner.jpg)">
            <div class="container slice-xl">
                <div class="row align-items-center">
                    <div class="col text-center">
                        <div class="animate-on-scroll fadeInUp heading-content">
                            <h3 class="heading heading-lg strong-600">
                                Lesene ograje
                            </h3>
                            <h3 class="heading heading-4 strong-300">
                                Estetska kombinacija funkcionalnosti uporabljenih materialov, ter odličen občutek zasebnosti vašega doma
                            </h3>
                            {% set blog = craft.entries().section('blogs').id(497).one() %}
                            <a href="{{ blog.url }}" class="d-flex justify-content-center align-items-center main-link mt-4">
                                <span class="text">
                                    {{ blog.blogInfo.naslov }}
                                </span>
                                <span class="button">
                                    <i class="fal fa-angle-right"></i>
                                </span>
                            </a>
                        </div>
                    </div>
                </div>
                <span class="clearfix"></span>
            </div>
        </section>

        <!-- Različne vrste izgledov -->
