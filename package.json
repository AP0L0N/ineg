        "laravel-mix": "^6.0.49",
        "lodash": "^4.17.20",
        "prettier": "1.12.1",
        "resolve-url-loader": "^5.0.0",
        "sass": "^1.74.1",
        "sass-loader": "^12.6.0",
        "vue": "^2.6.11"
    },
